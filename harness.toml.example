# ai-harness configuration. Copy to harness.toml and edit.

[server]
host = "127.0.0.1"
port = 8484

[backend]
kind = "openai"            # openai | vllm | llamacpp
base_url = "http://localhost:11434/v1"
model = "qwen2.5-coder:32b"
api_key = "local"

[profile]
name = "qwen"              # qwen | deepseek_r1 | devstral | gemma
context_window = 32768

[pipeline]
policy_owner = "harness"    # harness | agentic_os; agentic_os disables duplicate workflow/policy logic
system_prompt = "replace"  # replace | compress | passthrough
tool_prune = true
tool_catalog = true        # list every tool (1 line each) so the model can call hidden ones (requires tool_prune = true)
max_tools = 8
fewshot = true
repair_retries = 2
recent_turns_protected = 4
reasoning = "thinking"     # thinking | strip
workflow_guards = true
guard_edit_without_read = true
guard_verify_after_edit = true

[debug]
dump_prompts = false
dump_dir = "debug_dumps"

[planning]
enabled = false             # opt in: generate one plan per main session via a plan-role backend
max_steps = 8
max_chars = 4000

[routing]
reasoning = true            # route explanation/architecture/research turns to a reasoning-role backend
reasoning_readonly_tools = ["Read", "Grep", "Glob", "LS", "WebFetch"]

[review]
enabled = false             # opt in: strong-model critic for risky executor checkpoints
max_chars = 6000
max_tokens = 500
triggers = ["plan_drift", "verify_after_edit", "loop_break", "invalid_tool_retry"]

[critic]
enabled = false             # opt in: deliberate pre-action critic for risky recent work
max_chars = 12000
max_tokens = 1200
min_tool_calls = 1
triggers = ["risky_path", "edit", "build_failure", "test_failure", "tool_error"]

[reasoning_budget]
enabled = false             # opt in: send thinking_token_budget to capable reasoning backends
default_tokens = 1024
max_auto_tokens = 8192
max_manual_tokens = 32768
final_answer_reserve = 4096
load_shed = true
fallback_when_unavailable = "degrade"  # degrade | skip | fail

[reasoning_budget.role_tokens]
reasoning = 2048
plan = 4096
review = 2048
critic = 4096

[reasoning_budget.mode_tokens]
file_edit = 1024
hard_file_edit = 4096
project_survey = 8192
architecture_plan = 16384
deep_architecture_plan = 32768
integration_debug = 8192
kernel_change_plan = 16384
kernel_critic = 8192

[[risk_profiles]]
name = "kernel"
path_patterns = ["kernel/**", "drivers/**", "fs/**", "mm/**", "net/**", "include/linux/**"]
text_patterns = ["spinlock", "mutex", "rcu", "atomic", "refcount", "dma", "uaccess", "ioctl"]
plan_mode = "kernel_change_plan"
critic_mode = "kernel_critic"

[[risk_profiles]]
name = "c_api_refactor"
path_patterns = ["**/*.h", "**/*.c"]
text_patterns = ["struct ", "typedef", "extern ", "static inline", "#define"]
plan_mode = "architecture_plan"
critic_mode = "critic"

[skills]
enabled = false             # opt in: intercept Skill calls and inject compiled procedures
dir = "~/.codex/skills"
cache_dir = "~/.ai-harness/compiled-skills"
max_tokens = 400

[research]
enabled = false             # opt in: `research: <url-or-file>` brief injection
cache_dir = "~/.ai-harness/research"
max_chars = 12000
chunk_chars = 4000

# ---- fleet mode (preferred): one [[backends]] block per server ----
# [[backends]]
# name = "big"
# kind = "vllm"              # openai | vllm | llamacpp
# base_url = "http://host:8000/v1"
# model = "model-id"
